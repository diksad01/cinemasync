{
  "manifest_version": 3,
  "name": "SomniWatch — Watch Together",
  "description": "Sync videos with your partner in real time. Chat sidebar on YouTube.",
  "version": "2.0.0",
  "permissions": [
    "storage",
    "activeTab",
    "tabs"
  ],
  "host_permissions": [
    "*://*.youtube.com/*",
    "*://*.dailymotion.com/*",
    "*://*.vimeo.com/*",
    "*://*.twitch.tv/*",
    "*://*.netflix.com/*",
    "*://*.disneyplus.com/*",
    "*://*.hbomax.com/*",
    "*://*.primevideo.com/*"
  ],
  "background": {
    "service_worker": "service-worker-loader.js",
    "type": "module"
  },
  "action": {
    "default_popup": "src/popup/index.html"
  },
  "content_scripts": [
    {
      "js": [
        "assets/index.tsx-loader-CNQnCZ2W.js"
      ],
      "matches": [
        "*://*.youtube.com/*",
        "*://*.dailymotion.com/*",
        "*://*.vimeo.com/*",
        "*://*.twitch.tv/*",
        "*://*.netflix.com/*",
        "*://*.disneyplus.com/*",
        "*://*.hbomax.com/*",
        "*://*.primevideo.com/*"
      ],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "matches": [
        "*://*.dailymotion.com/*",
        "*://*.disneyplus.com/*",
        "*://*.hbomax.com/*",
        "*://*.netflix.com/*",
        "*://*.primevideo.com/*",
        "*://*.twitch.tv/*",
        "*://*.vimeo.com/*",
        "*://*.youtube.com/*"
      ],
      "resources": [
        "assets/client-B0HB0a3r.js",
        "assets/index.tsx-QVveRilE.js"
      ],
      "use_dynamic_url": false
    }
  ]
}
