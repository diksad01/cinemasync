{
  "manifest_version": 3,
  "name": "SomniWatch — Watch Together",
  "description": "Sync videos with your partner in real time. Chat sidebar on YouTube.",
  "version": "2.0.0",
  "permissions": ["storage", "activeTab", "tabs"],
  "host_permissions": [
    "*://*.youtube.com/*",
    "*://*.dailymotion.com/*",
    "*://*.vimeo.com/*",
    "*://*.twitch.tv/*",
    "*://*.netflix.com/*",
    "*://*.disneyplus.com/*",
    "*://*.hbomax.com/*",
    "*://*.primevideo.com/*"
  ],
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "action": {
    "default_popup": "src/popup/index.html"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.youtube.com/*",
        "*://*.dailymotion.com/*",
        "*://*.vimeo.com/*",
        "*://*.twitch.tv/*",
        "*://*.netflix.com/*",
        "*://*.disneyplus.com/*",
        "*://*.hbomax.com/*",
        "*://*.primevideo.com/*"
      ],
      "js": ["src/content/index.tsx"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
