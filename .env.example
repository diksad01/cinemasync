# Paystack — get from https://dashboard.paystack.com/#/settings/developers
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Firebase Admin SDK — paste the entire service account JSON as a single-line string
# Download from Firebase Console > Project Settings > Service Accounts > Generate new private key
# Then minify to one line: FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}
FIREBASE_SERVICE_ACCOUNT=

# App
APP_URL=https://watch.somniread.com
PORT=3001
