{
  "name": "somniwatch-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev:server": "node apps/server/server.js",
    "dev:web": "npm run dev -w apps/web",
    "dev:ext": "npm run dev -w apps/extension",
    "build": "npm run build -w apps/web",
    "build:web": "npm run build -w apps/web",
    "build:ext": "npm run build -w apps/extension",
    "start": "node server.js"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
